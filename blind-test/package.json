{
  "name": "blind-test",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yaml,yml}\" --write",
    "format:check": "prettier \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yaml,yml}\" --check",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --project unit",
    "test:unit:coverage": "vitest run --project unit --coverage",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:arch": "vitest run --project arch --passWithNoTests",
    "test:e2e": "playwright test",
    "test": "vitest run --project unit --project integration --project arch --passWithNoTests"
  },
  "dependencies": {
    "next": "16.2.5",
    "pusher": "^5.3.3",
    "pusher-js": "^8.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tinyglobby": "^0.2.16",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
